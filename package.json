{
  "name": "design-ready",
  "version": "0.1.0",
  "private": true,
  "description": "Figma plugin for file health check and semantic naming",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "build:dev": "DESIGN_READY_DEV=true node esbuild.config.mjs",
    "watch": "DESIGN_READY_DEV=true node esbuild.config.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "npm --prefix preview run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\""
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "preact": "^10.22.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.100.0",
    "esbuild": "^0.21.5",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  }
}
